#: check the code with cargo check, build, clippy and fmt
function check {
  cargo check
  cargo build
  cargo clippy && cargo fmt --check
}


#: clean the project
function clean {
  cargo clean
}


#: do cargo test
function test {
  cargo test -q -- --test-threads=1
}


#: run cspell to check the project words
function spell {
  spell-rs
}


#: space


#: start the service locally
function start {
  rm -rf ./target/release/notify-api
  cargo build --release

  set -a
  source res/envs/stg.env
  set +a

  ./target/release/notify-api
}


#: do graceful shutdown
function down {
  # Get the PID of your app
  pid=$(pgrep notify-api)

  if [ -z "$pid" ]; then
    echo "No process found for notify-api"
  else
    # Send the signal
    echo "Sending SIGTERM to process $pid..."
    kill -TERM $pid
  fi
}


#: space


#: open devbox shell #: opt: --fresh (delete .cargo and .rustup directories first)
function shell {
  if [ "$DEVBOX_SHELL_ENABLED" = "1" ]; then
    echo "ℹ️  You are already in an active Devbox shell."
    return 0
  fi

  if [[ $1 == "--fresh" ]]; then
    rm -rf .cargo .rustup
  fi

  DEVBOX_PROJECT_CWD="$PWD" devbox shell --config ~/.devbox/global/rust-1.96/devbox.json
}



#: build image
function build {
  docker build \
    -t notify-api:latest \
    -f res/Dockerfile \
    .
}


#: show unused dependencies
function udeps {
  cargo +nightly udeps
}


#: remove unused directories
function rmd {
  rm -rf .cargo .devbox .rustup debug target test-debug
}


